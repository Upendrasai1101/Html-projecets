<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Your Secret</title>
  <link rel="stylesheet" href="/css/main.css" />
</head>
<body>

  <div class="container">

    <div class="brand">
      <h1>🤫 Your Secret</h1>
      <p>Welcome, <strong><%= user %></strong>!</p>
    </div>

    <!-- Secret from API -->
    <div class="secret-box">
      <p class="secret-text">"<%= secret.secret %>"</p>
      <div class="secret-meta">
        <span>— <%= secret.username || "anonymous" %></span>
        <% if (secret.score) { %>
          <span class="score">⭐ <%= secret.score.toFixed(1) %></span>
        <% } %>
      </div>
    </div>

    <div class="actions">
      <a href="/secrets" class="btn-refresh">🔄 New Secret</a>
      <a href="/logout" class="btn-logout">Logout</a>
    </div>

  </div>

</body>
</html>
