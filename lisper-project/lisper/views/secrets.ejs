<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Secrets — Lisper</title>
  <link rel="stylesheet" href="/css/style.css" />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet"/>
</head>
<body class="page-secrets">

  <div class="grain"></div>

  <nav class="nav">
    <a href="/" class="logo">🤫 lisper</a>
    <div class="nav-right">
      <span class="nav-user">👤 <%= user.email.split('@')[0] %></span>
      <a href="/logout" class="nav-link">Logout</a>
    </div>
  </nav>

  <main class="secrets-main">

    <div class="secrets-header">
      <h1>The Vault</h1>
      <p>Secrets shared by strangers. Handle with care.</p>
    </div>

    <div class="secret-stage">
      <div class="secret-card" id="secretCard">
        <div class="secret-meta-top">
          <div class="score-badge">
            <span class="score-num" id="secretScore"><%= secret.score ? secret.score.toFixed(1) : '—' %></span>
            <span class="score-label">resonance</span>
          </div>
          <div class="whisper-label">🤫 whisper</div>
        </div>

        <blockquote class="secret-text" id="secretText">
          "<%= secret.secret %>"
        </blockquote>

        <div class="secret-footer">
          <span class="secret-author">— <em id="secretAuthor"><%= secret.username || 'anonymous' %></em></span>
        </div>
      </div>

      <div class="secret-actions">
        <button class="btn-reveal" id="revealBtn" onclick="loadNewSecret()">
          <span class="btn-icon">🌀</span>
          Reveal Another Secret
        </button>
        <p class="reveal-hint">Every click reveals a new confession from the void.</p>
      </div>
    </div>

    <div class="secrets-grid-label">
      <span>Recent whispers from the community</span>
    </div>

    <div class="secrets-grid" id="secretsGrid">
      <!-- Populated by JS -->
    </div>

  </main>

  <script src="/js/secrets.js"></script>
</body>
</html>
